{
  "name": "dcs98",
  "version": "3.20.0",
  "private": true,
  "description": "Ghost Intel 98 — Windows 98–inspired OSINT/case-management desktop app. Electron + React + TypeScript.",
  "author": {
    "name": "Desirae Stark",
    "email": "213370007+Dezirae-Stark@users.noreply.github.com"
  },
  "homepage": "https://github.com/Obsidian-Circuit-LLC/ghost-intel-98",
  "license": "MIT",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "gate:confinement": "bash scripts/gates/osint-confinement-netns.sh 18443 203.0.113.0/24",
    "fetch:tor": "node scripts/fetch-tor.mjs",
    "fetch:piper": "node scripts/fetch-piper.mjs",
    "fetch:mlkem": "node scripts/fetch-mlkem.mjs",
    "fetch:embed": "node scripts/fetch-embed.mjs",
    "fetch:tle-snapshot": "node scripts/fetch-tle-snapshot.mjs",
    "package": "pnpm fetch:tor && pnpm fetch:piper && pnpm fetch:mlkem && pnpm fetch:embed && pnpm fetch:tle-snapshot && pnpm build && electron-builder",
    "package:win": "pnpm fetch:tor && pnpm fetch:piper && pnpm fetch:mlkem && pnpm fetch:embed && pnpm fetch:tle-snapshot && pnpm build && electron-builder --win --x64",
    "package:linux": "pnpm build && electron-builder --linux",
    "postinstall": "echo 'native: ssh2 is pure-JS; node-pty is an optional native addon (lazy-loaded, fail-safe) — needs an Electron-ABI rebuild on the Windows packaging host'"
  },
  "dependencies": {
    "98.css": "^0.1.20",
    "@noble/ciphers": "2.2.0",
    "@noble/curves": "2.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.17",
    "basic-ftp": "^6.0.1",
    "dompurify": "^3.4.7",
    "exifr": "^7.1.3",
    "fast-xml-parser": "^5.8.0",
    "hls.js": "^1.6.16",
    "imapflow": "^1.3.3",
    "mailparser": "^3.9.8",
    "mammoth": "^1.12.0",
    "maplibre-gl": "^5.24.0",
    "music-metadata": "^11.12.3",
    "nodemailer": "^8.0.8",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "satellite.js": "^5.0.0",
    "ssh2": "^1.17.0",
    "vosk-browser": "^0.0.8",
    "ws": "^8.21.0",
    "zustand": "^5.0.2"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@noble/post-quantum": "0.6.1",
    "@types/adm-zip": "^0.5.8",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.17.10",
    "@types/nodemailer": "^8.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "an-array-of-english-words": "^2.0.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "world-countries": "^5.1.0"
  },
  "build": {
    "appId": "com.ghostintel.ghostintel98",
    "productName": "Ghost Intel 98",
    "directories": {
      "output": "release/${version}",
      "buildResources": "resources"
    },
    "npmRebuild": false,
    "publish": null,
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "files": [
      "out/**/*",
      "package.json",
      "!node_modules/**/cpu-features/**"
    ],
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      },
      {
        "from": "resources/logo.png",
        "to": "logo.png"
      },
      {
        "from": "resources/geoint",
        "to": "geoint"
      },
      {
        "from": "resources/firefox",
        "to": "firefox"
      },
      {
        "from": "resources/vosk",
        "to": "vosk"
      },
      {
        "from": "resources/tor",
        "to": "tor"
      },
      {
        "from": "resources/piper",
        "to": "piper"
      },
      {
        "from": "resources/mlkem",
        "to": "mlkem"
      },
      {
        "from": "resources/exiftool",
        "to": "exiftool"
      },
      {
        "from": "resources/local-ai",
        "to": "local-ai"
      },
      {
        "from": "resources/sounds",
        "to": "sounds"
      },
      {
        "from": "resources/satellites",
        "to": "satellites"
      },
      {
        "from": "resources/searchlight",
        "to": "searchlight"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "artifactName": "GhostIntel98-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ghost Intel 98",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "icon": "resources/icon.png",
      "artifactName": "GhostIntel98-${version}.${ext}"
    }
  }
}
