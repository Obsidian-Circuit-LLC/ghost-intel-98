{
  "name": "ghost-access-98",
  "version": "0.1.0-pre",
  "private": true,
  "description": "Windows 98–inspired case-management desktop app. Electron + React + TypeScript.",
  "author": {
    "name": "Desirae Stark",
    "email": "213370007+Dezirae-Stark@users.noreply.github.com"
  },
  "homepage": "https://github.com/Dezirae-Stark/ghost-access-98",
  "license": "MIT",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "pnpm build && electron-builder",
    "package:win": "pnpm build && electron-builder --win --x64",
    "package:linux": "pnpm build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "98.css": "^0.1.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.obsidiancircuit.ghostaccess98",
    "productName": "Ghost Access 98",
    "directories": {
      "output": "release/${version}",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "GhostAccess98-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ghost Access 98"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Utility",
      "artifactName": "GhostAccess98-${version}.${ext}"
    }
  }
}
