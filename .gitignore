# Packaged artefacts
*.exe
*.dmg
*.AppImage
*.deb
*.snap
*.zip

# User runtime data (in case it ever lands inside the repo by accident)
/GhostAccess98-data/

# Internal audit/working notes — never published
.redteam/

# Dev signing keypair (private keys — NEVER commit)
.plugin-devkey.json

# Bundled Tor expert bundle (operator/CI-fetched + verified; see scripts/fetch-tor.mjs)
resources/tor/win-x64/

# Bundled Piper TTS binary + voice model (operator/CI-fetched + verified; see scripts/fetch-piper.mjs)
resources/piper/win-x64/

# Bundled ML-KEM-1024 helper binaries (built per-platform; see tools/mlkem-helper/build.sh).
# The README + C source ARE committed; the compiled binaries are not.
resources/mlkem/*/mlkem-helper
resources/mlkem/*/mlkem-helper.exe

# Bundled ExifTool (operator-supplied per platform; see resources/exiftool/README-EXIFTOOL.txt).
# The README is committed; the binaries/Perl distribution are not.
resources/exiftool/*/

# Bundled local-AI resources (embedding model staged by `pnpm fetch:embed`; see README-LOCAL-AI.txt).
# The README is committed; the model blobs + marker are build/CI-supplied, not committed.
resources/local-ai/models/
resources/local-ai/EMBED_MODEL_PRESENT

# twscrape-runner PyInstaller sidecar — per-platform built binaries (operator build gate; not committed)
resources/twscrape-runner/linux-x64/
resources/twscrape-runner/mac-x64/
resources/twscrape-runner/mac-arm64/
resources/twscrape-runner/win-x64/
# twscrape-runner build artefacts (venv, vendor cache, PyInstaller work dir, spec file)
resources/twscrape-runner/.venv-build/
resources/twscrape-runner/vendor/
resources/twscrape-runner/.build-work/
resources/twscrape-runner/twscrape-runner.spec

# python bytecode from confinement gate scripts
scripts/gates/__pycache__/
__pycache__/

# Rust build artifacts (confinement native binary; never commit the target/ dir)
native/dcs98-confine/target/
